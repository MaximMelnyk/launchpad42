# 42 LaunchPad — Frontend Environment Variables
# Copy to .env and fill in values:  cp .env.example .env

# API endpoint (local dev: http://localhost:8080, prod: Cloud Run URL)
VITE_API_URL=http://localhost:8080

# Firebase configuration (get from Firebase Console → Project Settings)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=launchpad42-prod.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=launchpad42-prod
VITE_FIREBASE_STORAGE_BUCKET=launchpad42-prod.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
