rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Deny-all default
    match /{document=**} {
      allow read, write: if false;
    }

    // User profile: owner can read freely, write restricted to safe fields
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid
        && (!request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['level', 'xp', 'streak_days', 'shields', 'current_day', 'phase', 'weekly_completed_days', 'telegram_chat_id']));
    }

    // Exercise progress: uid-scoped via field check
    match /exercise_progress/{docId} {
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
    }

    // Sessions: uid-scoped via field check
    match /sessions/{docId} {
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
    }

    // Exercises: read-only for authenticated users (seeded by admin/server)
    match /exercises/{exerciseId} {
      allow read: if request.auth != null;
    }

    // Vocab: read-only for authenticated users (seeded by admin/server)
    match /vocab/{termId} {
      allow read: if request.auth != null;
    }

    // Review cards: server-only writes, authenticated reads
    match /review_cards/{cardId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Achievements: uid-scoped via field check (server writes, client reads)
    match /achievements/{docId} {
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // Drill pool: read-only for client, writes via server Admin SDK only
    match /drill_pool/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Tutor usage counters: server-only (Admin SDK)
    match /tutor_usage/{docId} {
      allow read, write: if false;
    }

    // Tutor conversation history: server-only (Admin SDK)
    match /tutor_history/{uid} {
      allow read, write: if false;
    }

    // Exams: uid-scoped via field check (server manages, client reads)
    match /exams/{docId} {
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // Telegram links: server-only (no client access)
    match /telegram_links/{chatId} {
      allow read, write: if false;
    }

    // Telegram rate limit: server-only (brute-force protection)
    match /telegram_rate_limit/{chatId} {
      allow read, write: if false;
    }
  }
}
